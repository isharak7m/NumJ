# Sonatype Central Portal deployment token (generate at https://central.sonatype.com)
sonatypeUser=your-token-username
sonatypePassword=your-token-password

# GPG signing (generate with: gpg --full-gen-key)
signing.keyId=<last-8-chars-of-key-id>
signing.password=your-gpg-passphrase
signing.secretKeyRingFile=C:/projects/numj/secring.gpg

# Release version
VERSION=0.1.0
