# Sonatype Central Portal credentials (generate at https://central.sonatype.com)
sonatypeUser=your-token-username
sonatypePassword=your-token-password

# GPG signing (generate with: gpg --full-gen-key)
signing.keyId=ABC123DEF456
signing.password=your-gpg-passphrase
signing.secretKeyRingFile=C:/Users/you/.gnupg/secring.gpg

# Release version (remove -SNAPSHOT for release)
VERSION=0.1.0
